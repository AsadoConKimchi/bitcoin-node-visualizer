# ── Bitcoin Core / Knots RPC ──────────────────────
# Umbrel 사용자: SSH 접속 후 아래 명령으로 확인
#   ssh umbrel@<tailscale-ip>
#   cat ~/umbrel/app-data/bitcoin/data/bitcoin/bitcoin.conf | grep rpc
# 또는 Umbrel 대시보드 → Bitcoin Node → 연결 정보 확인
BITCOIN_RPC_HOST=100.x.x.x        # Umbrel Tailscale IP
BITCOIN_RPC_PORT=8332
BITCOIN_RPC_USER=umbrel
BITCOIN_RPC_PASS=your_rpc_password

# ── ZMQ (선택) ────────────────────────────────────
# bitcoin.conf에 아래 설정이 필요:
#   zmqpubrawblock=tcp://0.0.0.0:28332
#   zmqpubrawtx=tcp://0.0.0.0:28333
# ZMQ 미설정 시 자동으로 RPC 폴링으로 전환됨
BITCOIN_ZMQ_HOST=100.x.x.x
BITCOIN_ZMQ_RAWBLOCK_PORT=28332
BITCOIN_ZMQ_RAWTX_PORT=28333

# ── 서버 ──────────────────────────────────────────
PORT=3000
